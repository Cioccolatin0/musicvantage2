# PostgreSQL connection
DATABASE_URL=postgresql://musicvantage2:password@localhost:5432/musicvantage2

# Server port (default 3001)
PORT=3001

# --- yt-dlp proxy settings (optional) ---
# Single fixed proxy:
# YT_PROXY=http://user:pass@1.2.3.4:8080
# Comma-separated rotating proxies (picks random per request):
# YT_PROXY_LIST=http://user:pass@1.2.3.4:8080,http://user:pass@5.6.7.8:8080

# --- yt-dlp cookies file (optional) ---
# Path to Netscape-format cookies.txt for authenticated requests.
# Generate with: python extract_cookies.py
# YT_COOKIES_FILE=./cookies.txt
